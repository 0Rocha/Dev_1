# =============================================================================
# Template de variáveis de ambiente
# Copie para .env e preencha os valores. Não commitar .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Web-proxy (container app) — para reverse proxy e Let's Encrypt
# -----------------------------------------------------------------------------
VIRTUAL_HOST=meuapp.local
VIRTUAL_PORT=3000
LETSENCRYPT_HOST=meuapp.local

# -----------------------------------------------------------------------------
# Banco de dados PostgreSQL (app e db)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=altere_senha_segura
POSTGRES_DB=appdb

# URL de conexão usada pelo Next.js (host = nome do serviço "db" no compose)
# Use os mesmos valores de POSTGRES_USER, POSTGRES_PASSWORD e POSTGRES_DB
DATABASE_URL=postgresql://postgres:altere_senha_segura@db:5432/appdb

# -----------------------------------------------------------------------------
# App (opcional)
# -----------------------------------------------------------------------------
NODE_ENV=production
# NEXT_PUBLIC_* conforme necessidade da aplicação
