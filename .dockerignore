# -----------------------------------------------------------------------------
# .dockerignore — reduz contexto de build e evita conflitos
# Plano: node_modules, .next, .git, .env* (exceto .env.docker se desejado)
# -----------------------------------------------------------------------------

# Dependências (reinstaladas no build)
node_modules
**/node_modules

# Build do Next.js (gerado no container)
.next
**/.next

# Controle de versão
.git
.gitignore

# Variáveis de ambiente (não versionar no image; usar env no compose)
.env
.env.*
!.env.docker
.env.docker.local  
# IDE / editor
.cursor
.vscode
*.swp
*.swo

# Logs e cache local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.cache

# Testes e cobertura (não necessários no image de produção)
coverage
.nyc_output
**/__tests__
**/*.test.*
**/*.spec.*

# Documentação e artefatos fora do app (opcional)
*.md
!app/**/*.md
